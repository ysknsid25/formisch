{
  "name": "@formisch/preact",
  "description": "The lightweight, schema-first, and fully type-safe form library for Preact",
  "version": "0.10.0",
  "license": "MIT",
  "author": "Fabian Hiller",
  "homepage": "https://formisch.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-circle/formisch"
  },
  "keywords": [
    "preact",
    "form",
    "typescript",
    "schema",
    "validation"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --typecheck",
    "lint": "eslint \"src/**/*.ts*\" && tsc --noEmit",
    "lint.fix": "eslint \"src/**/*.ts*\" --fix",
    "format": "prettier --write ./src",
    "format.check": "prettier --check ./src"
  },
  "devDependencies": {
    "@formisch/core": "workspace:*",
    "@formisch/eslint-config": "workspace:*",
    "@formisch/methods": "workspace:*",
    "@preact/preset-vite": "^2.10.5",
    "@preact/signals": "^2.9.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "24.0.13",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.31.0",
    "eslint-config-preact": "^2.0.0",
    "jsdom": "^26.1.0",
    "preact": "^10.29.2",
    "tsdown": "^0.16.8",
    "typescript": "^5.8.3",
    "valibot": "^1.4.1",
    "vite": "^6.0.4",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@preact/signals": "^2.0.0",
    "preact": "^10.0.0",
    "typescript": ">=5",
    "valibot": "^1.4.1"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}

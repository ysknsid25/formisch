{
  "name": "formisch",
  "description": "The lightweight, schema-first, and fully type-safe form library for React, Solid, Vue, Svelte and more",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Fabian Hiller",
  "homepage": "https://formisch.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-circle/formisch"
  },
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "build": "pnpm run build-packages && pnpm run build-frameworks",
    "build-packages": "pnpm --filter './packages/*' --if-present build",
    "build-frameworks": "pnpm --filter './frameworks/*' --if-present build",
    "lint": "pnpm run lint-packages && pnpm run lint-frameworks && pnpm run lint-website && pnpm run lint-playgrounds",
    "lint-packages": "pnpm --filter './packages/*' --if-present lint",
    "lint-frameworks": "pnpm --filter './frameworks/*' --if-present lint",
    "lint-website": "pnpm --filter './website' --if-present lint",
    "lint-playgrounds": "pnpm --filter './playgrounds/*' --if-present lint",
    "format": "pnpm run format-packages && pnpm run format-frameworks && pnpm run format-website && pnpm run format-playgrounds",
    "format-packages": "pnpm --filter './packages/*' --if-present format",
    "format-frameworks": "pnpm --filter './frameworks/*' --if-present format",
    "format-website": "pnpm --filter './website' --if-present format",
    "format-playgrounds": "pnpm --filter './playgrounds/*' --if-present format",
    "format-check": "pnpm run format-check-packages && pnpm run format-check-frameworks && pnpm run format-check-website && pnpm run format-check-playgrounds",
    "format-check-packages": "pnpm --filter './packages/*' --if-present format.check",
    "format-check-frameworks": "pnpm --filter './frameworks/*' --if-present format.check",
    "format-check-website": "pnpm --filter './website' --if-present format.check",
    "format-check-playgrounds": "pnpm --filter './playgrounds/*' --if-present format.check",
    "test": "pnpm run test-packages && pnpm run test-frameworks",
    "test-packages": "pnpm --filter './packages/*' --if-present test",
    "test-frameworks": "pnpm --filter './frameworks/*' --if-present test",
    "check-versions": "pnpm --filter formisch-scripts check-versions",
    "create-releases": "pnpm --filter formisch-scripts create-releases"
  },
  "devDependencies": {
    "@babel/plugin-syntax-class-properties": "^7.12.13",
    "@babel/plugin-syntax-jsx": "^7.27.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.8.3"
  }
}
